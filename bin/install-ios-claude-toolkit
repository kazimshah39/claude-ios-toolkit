#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SHARED_CLAUDE="$TOOLKIT_DIR/CLAUDE.md"
SHARED_SKILLS_DIR="$TOOLKIT_DIR/skills"
PROJECT_DIR="${1:-$PWD}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"
PROJECT_CLAUDE_DIR="$PROJECT_DIR/.claude"
PROJECT_CLAUDE="$PROJECT_CLAUDE_DIR/CLAUDE.md"
PROJECT_SKILLS_DIR="$PROJECT_CLAUDE_DIR/skills"
SHARED_BLOCK_START="<!-- claude-ios-toolkit:start -->"
SHARED_BLOCK_END="<!-- claude-ios-toolkit:end -->"

if [[ ! -f "$SHARED_CLAUDE" ]]; then
  echo "Error: shared CLAUDE.md not found at $SHARED_CLAUDE" >&2
  exit 1
fi

if [[ ! -d "$SHARED_SKILLS_DIR" ]]; then
  echo "Error: shared skills directory not found at $SHARED_SKILLS_DIR" >&2
  exit 1
fi

mkdir -p "$PROJECT_CLAUDE_DIR" "$PROJECT_SKILLS_DIR"

shared_block="$(mktemp)"
{
  printf '%s\n' "$SHARED_BLOCK_START"
  cat "$SHARED_CLAUDE"
  printf '\n%s\n' "$SHARED_BLOCK_END"
} > "$shared_block"

if [[ ! -f "$PROJECT_CLAUDE" ]]; then
  cp "$shared_block" "$PROJECT_CLAUDE"
  echo "Created .claude/CLAUDE.md with shared iOS instructions."
elif grep -Fq "$SHARED_BLOCK_START" "$PROJECT_CLAUDE" && grep -Fq "$SHARED_BLOCK_END" "$PROJECT_CLAUDE"; then
  tmp_file="$(mktemp)"
  python3 - "$PROJECT_CLAUDE" "$shared_block" "$SHARED_BLOCK_START" "$SHARED_BLOCK_END" > "$tmp_file" <<'PY'
import sys
project_path, block_path, start, end = sys.argv[1:]
project = open(project_path, encoding="utf-8").read()
block = open(block_path, encoding="utf-8").read().rstrip() + "\n"
start_index = project.index(start)
end_index = project.index(end, start_index) + len(end)
updated = project[:start_index] + block + project[end_index:]
print(updated, end="")
PY
  mv "$tmp_file" "$PROJECT_CLAUDE"
  echo "Updated shared iOS instructions block in .claude/CLAUDE.md."
else
  tmp_file="$(mktemp)"
  {
    cat "$shared_block"
    printf '\n'
    cat "$PROJECT_CLAUDE"
  } > "$tmp_file"
  mv "$tmp_file" "$PROJECT_CLAUDE"
  echo "Added shared iOS instructions block to top of .claude/CLAUDE.md."
fi

rm "$shared_block"

copied_count=0
skipped_count=0
updated_count=0

for skill_dir in "$SHARED_SKILLS_DIR"/*; do
  [[ -d "$skill_dir" ]] || continue
  [[ -f "$skill_dir/SKILL.md" ]] || continue

  skill_name="$(basename "$skill_dir")"
  destination="$PROJECT_SKILLS_DIR/$skill_name"

  if [[ -d "$destination" && -f "$destination/.ios-claude-toolkit-skill" ]]; then
    rm -rf "$destination"
    cp -R "$skill_dir" "$destination"
    touch "$destination/.ios-claude-toolkit-skill"
    echo "Updated copied skill: $skill_name"
    updated_count=$((updated_count + 1))
  elif [[ -e "$destination" ]]; then
    echo "Skipped existing project skill: $skill_name"
    skipped_count=$((skipped_count + 1))
  else
    cp -R "$skill_dir" "$destination"
    touch "$destination/.ios-claude-toolkit-skill"
    echo "Copied skill: $skill_name"
    copied_count=$((copied_count + 1))
  fi
done

echo
echo "Installed iOS Claude Code toolkit in: $PROJECT_DIR"
echo "Copied: $copied_count, updated: $updated_count, skipped: $skipped_count"
echo "Project instructions: $PROJECT_CLAUDE"
echo "Project skills: $PROJECT_SKILLS_DIR"
